{
  "name": "uzorai",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "UzorAI / uzorai.com — HTU framework scaffold (React 19 + Vite + Hono on Cloudflare Workers). Phase 1 of REFACTOR #15; additive and isolated from the production static site.",
  "scripts": {
    "dev": "vite",
    "test": "node scripts/assert-no-translate.mjs",
    "build": "node scripts/assert-no-translate.mjs && tsc --noEmit && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wrangler": "^3.99.0"
  }
}
