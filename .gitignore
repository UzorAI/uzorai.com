# Scaffold build artifacts (REFACTOR #15 Phase 1).
# Kept out of git so the production deploy (git archive HEAD -> Pages static
# upload, see .github/workflows/deploy.yml) never ships node_modules or dist.
node_modules/
dist/
.wrangler/
*.log

# Windows / WSL "mark of the web" metadata — rides along on /mnt/c copies; never track.
*:Zone.Identifier
